# Telegram
BOT_TOKEN=123456789:replace_with_token_from_BotFather
# Optional. If empty, the first Telegram user who opens /start becomes the owner.
ADMIN_TELEGRAM_IDS=123456789

# Shadowsocks / Outline-compatible VPN settings
SS_PORT=8388
SS_METHOD=chacha20-ietf-poly1305
SS_TIMEOUT=300
SS_KEY_NAME=Railway Outline VPN
ENABLE_UDP=false

# Optional manual override. Usually Railway fills these after TCP Proxy is enabled.
# SS_PUBLIC_HOST=roundhouse.proxy.rlwy.net
# SS_PUBLIC_PORT=11105

# Persistent state. Add a Railway Volume mounted to /data if you want the key to survive redeploys.
STATE_PATH=/data/outline_state.json
